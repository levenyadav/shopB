# Copy this file to .env and fill in your real Supabase values.
# Find these in: Supabase Dashboard → Project Settings → API
# NEVER commit the real .env (it is gitignored).

# Vite exposes only vars prefixed with VITE_ to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# TESTING ONLY — no SMS provider is wired yet. Set this to the fixed code you
# registered under Supabase Dashboard → Authentication → Providers → Phone →
# "Test OTP" for your test number. The login screen then shows this code so you
# can sign in without an SMS (Supabase still verifies it → real session).
# Leave BLANK / delete this line for production with real SMS.
# VITE_DEV_OTP=123456

# Server-only (Edge Functions / migrations). Keep OUT of the frontend bundle.
# Used by the Supabase CLI and edge functions, not by Vite.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=YOUR-PROJECT-ref
