# Copy this file to .env and fill in your real Supabase values.
# Find these in: Supabase Dashboard → Project Settings → API
# NEVER commit the real .env (it is gitignored).

# Vite exposes only vars prefixed with VITE_ to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# TESTING ONLY — no SMS provider is wired yet. Set this to the fixed code you
# registered under Supabase Dashboard → Authentication → Providers → Phone →
# "Test OTP" for your test number. The login screen then shows this code so you
# can sign in without an SMS (Supabase still verifies it → real session).
# Leave BLANK / delete this line for production with real SMS.
# VITE_DEV_OTP=123456

# Firebase Phone Auth (real SMS for login). Fill from Firebase Console → Project
# settings → General → Your apps (Web) → "SDK setup and configuration". Setting
# VITE_FIREBASE_API_KEY switches login from the DEV_OTP mock to real Firebase SMS.
# These web keys are PUBLIC by design (access is gated by Firebase authorized
# domains + the firebase-otp-login Edge Function), so they are safe in the bundle.
# VITE_FIREBASE_API_KEY=your-web-api-key
# VITE_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=YOUR-PROJECT
# VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef

# Server-only (Edge Functions / migrations). Keep OUT of the frontend bundle.
# Used by the Supabase CLI and edge functions, not by Vite.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=YOUR-PROJECT-ref

# Edge Function secret for the Firebase→Supabase login bridge. This is the
# Firebase PROJECT ID (used to validate token aud/iss). Set it with:
#   supabase secrets set FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PROJECT_ID=your-firebase-project-id
