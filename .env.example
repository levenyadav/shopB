# Copy this file to .env and fill in your real Supabase values.
# Find these in: Supabase Dashboard → Project Settings → API
# NEVER commit the real .env (it is gitignored).

# Vite exposes only vars prefixed with VITE_ to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Login SMS is sent by Fast2SMS via the `phone-otp` Edge Function. There is NO
# frontend key: the API key is a SERVER secret (never VITE_-prefixed, never in
# the browser bundle). Set it on the function with:
#   supabase secrets set FAST2SMS_API_KEY=your-fast2sms-api-key

# Server-only (Edge Functions / migrations). Keep OUT of the frontend bundle.
# Used by the Supabase CLI and edge functions, not by Vite.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=YOUR-PROJECT-ref

# Fast2SMS API key — the login OTP sender. Get it from
# https://www.fast2sms.com/dashboard/dev-api and set it as an Edge Function
# secret (NOT here in the bundle):  supabase secrets set FAST2SMS_API_KEY=...
# FAST2SMS_API_KEY=your-fast2sms-api-key
